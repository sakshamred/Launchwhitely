# Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public site URL — used to build OAuth redirect URLs.
# Set to your production domain in prod, leave unset in dev (origin header is used).
# NEXT_PUBLIC_SITE_URL=https://launchwhitly.example.com

# Launchwhitly SDK base URL and keys for application code.
# NEXT_PUBLIC_LAUNCHWHITLY_URL=https://launchwhitly.example.com
# LW_PROJECT_KEY=lw_prj_...
# LW_ENVIRONMENT_KEY=lw_env_...

# PostgreSQL connection strings
# DATABASE_URL  – pooled via Supavisor (used by Prisma Client at runtime)
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# DIRECT_URL – non-pooled (used by Prisma CLI for migrations)
DIRECT_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:5432/postgres

# Resend — transactional email for invite notifications.
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# Email "from" address (must be verified in Resend). For dev you can use:
#   Launchwhitly <onboarding@resend.dev>
RESEND_FROM=Launchwhitly <noreply@your-domain.com>
